# ─────────────────────────────────────────────────────────────────────────────
# LOCAL dev — copy to `.env.local` and run the whole app on your laptop.
#   npm run db:start   (boots the local Supabase stack in Docker)
#   npm run dev        (Next dev server on http://localhost:3000)
# Runbook: companies/dott-comm/content/knowledge/local-dev-testing.md
#
# These values wire the app at the LOCAL Supabase stack (`npm run db:status`
# prints the ports/keys). None of these are secrets — the keys below are the
# standard local Supabase demo keys, identical for every local project. For the
# PROD / dashboards checklist see `.env.example` + dev-setup-guide.md.
# ─────────────────────────────────────────────────────────────────────────────

# --- Auth: Better Auth (website sessions + MCP Authorization Server) ---
# Issuer origin = the local dev server. No trailing slash.
BETTER_AUTH_URL=http://localhost:3000
# Any string works locally (dev-only, not for prod).
BETTER_AUTH_SECRET=dev-better-auth-secret-not-for-prod-0000000000
# Direct Postgres for Better Auth's tables = the local stack DB (host port 54322).
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres

# Email sender for magic links: LEAVE RESEND_API_KEY UNSET locally. The magic
# link then prints to the `npm run dev` console (src/lib/auth.ts) — copy it into
# the browser to complete sign-in. No email provider needed.
RESEND_API_KEY=
MAGIC_LINK_FROM=DottComm <onboarding@resend.dev>

# --- MCP server auth ---
# Keep auth OFF locally for the fast faked-identity loop. Flip to `true` to
# exercise the real OAuth dance (DCR → magic-link sign-in → consent → token)
# against local Better Auth via `npx @modelcontextprotocol/inspector`.
MCP_REQUIRE_AUTH=false
# This server's MCP URL (bound as the token `resource`).
MCP_RESOURCE_URL=http://localhost:3000/api/mcp
# Faked identity: tool calls run as this user against the local billing gate.
# Point it at a seeded row (supabase/seed.sql) to pick a paywall state:
#   dev_trial | dev_active | dev_canceled | dev_trial_spent
# Leave unset to run tools ungated (pure fiscal tools, no Supabase).
MCP_DEV_USER_ID=dev_trial

# --- Billing: Supabase (LOCAL stack) ---
# API URL + the local service_role key (the standard local demo JWT; the same
# value for every local project — `npm run db:status` also prints it, plus an
# `sb_secret_…` form which works too).
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Low cap so you hit the paywall after 3 calls instead of 50.
TRIAL_TOOL_CALL_LIMIT=3
DAILY_TOOL_CALL_LIMIT=2

# Local site origin — used for the /upgrade link inside tool responses.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Signs the short-lived /upgrade?t=… token (min 24 chars). Dev-only value.
UPGRADE_TOKEN_SECRET=dev-upgrade-token-secret-000000000000

# --- Billing: Stripe (optional locally) ---
# Leave blank unless testing the real payment loop. Then use TEST-mode keys and
# `stripe listen --forward-to localhost:3000/api/stripe/webhook` (prints the
# STRIPE_WEBHOOK_SECRET). See content/knowledge/local-dev-testing.md.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# --- Corpus retrieval (ADR 0014) ---
# Cohere embed-v4 per la ricerca semantica del corpus (query-time nell'app +
# indicizzazione negli script di ingestione). Senza chiave, `corpus_cerca`
# degrada al solo full-text e lo dichiara (nessun risultato peggiore spacciato
# per buono). Chiave: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=
# Interruttori del retrieval (opt-out espliciti, non legati alla sola chiave —
# vedi src/lib/corpus/config.ts). Default: attivi quando COHERE_API_KEY c'è.
#   CORPUS_EMBEDDINGS=false → ricerca densa off a query-time (solo full-text),
#     utile per debug o per tagliare le chiamate embedding anche con la chiave.
#   CORPUS_RERANK=false     → niente reranker Cohere rerank-3.5 (chiamata a
#     pagamento sull'hot path); i risultati restano nell'ordine ibrido RRF.
# CORPUS_EMBEDDINGS=true
# CORPUS_RERANK=true
# Solo per gli script di ingestione/arricchimento (mai nell'app): pass LLM di
# estrazione citazioni ambigue via Batch API Anthropic.
ANTHROPIC_API_KEY=
