# --- MCP server auth (WorkOS AuthKit) ---
# Enforce OAuth on the MCP endpoint. Leave unset/false for open local dev.
MCP_REQUIRE_AUTH=false

# Your WorkOS AuthKit domain — the OAuth Authorization Server (issuer + JWKS base).
# Find it in the WorkOS Dashboard. Example:
AUTHKIT_DOMAIN=https://your-app.authkit.app

# This server's public MCP URL. Used as the token audience (Resource Indicator)
# and must match the resource registered in the WorkOS Dashboard. Example:
MCP_RESOURCE_URL=https://dott-comm.vercel.app/api/mcp

# --- Billing: Supabase entitlement/usage store (ADR 0002) ---
# Project URL + service_role key (server-only — the anon key is never used).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Free-trial cap: tool calls before the paywall kicks in.
TRIAL_TOOL_CALL_LIMIT=50

# Canonical site URL — used to build the /upgrade link inside tool responses.
NEXT_PUBLIC_SITE_URL=https://www.dottcomm.dev

# Secret for the short-lived signed token in the paywall /upgrade?t=… link,
# which lets a paywalled user reach Stripe Checkout without re-login. Optional:
# falls back to WORKOS_COOKIE_PASSWORD; if neither is set the link degrades to
# the plain /upgrade + sign-in flow. Generate with: openssl rand -base64 24
UPGRADE_TOKEN_SECRET=

# Dev only: with MCP_REQUIRE_AUTH=false, set a fake user id to exercise the
# billing gate without OAuth. Leave unset to run tools ungated locally.
MCP_DEV_USER_ID=

# --- Billing: website AuthKit sessions (/upgrade, /account) ---
# Same WorkOS environment that authorizes the MCP, so the website user id
# matches the MCP token's `sub`. Register the redirect URI in the Dashboard.
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
# 32+ chars — generate with: openssl rand -base64 24
WORKOS_COOKIE_PASSWORD=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# --- Billing: Stripe ---
STRIPE_SECRET_KEY=
# From the Dashboard webhook endpoint (prod) or `stripe listen` (local).
STRIPE_WEBHOOK_SECRET=
# The flat monthly subscription price.
STRIPE_PRICE_ID=
