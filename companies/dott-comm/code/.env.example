# --- Auth: Better Auth (website sessions + MCP Authorization Server) ---
# Better Auth runs in-process and is BOTH the website session provider and the
# OAuth 2.1 Authorization Server for the MCP. It stores its tables in the same
# Supabase Postgres over a direct connection (DATABASE_URL below).

# Canonical base URL of the app (the OAuth issuer origin). No trailing slash.
BETTER_AUTH_URL=https://www.dottcomm.dev
# Server secret for signing sessions/tokens. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Direct Postgres connection string for Better Auth's tables. Use the Supabase
# SESSION POOLER string (Project Settings → Database) — the port-5432 form
# avoids the pgbouncer prepared-statement issues you hit with the transaction
# pooler (port 6543) under `pg`.
DATABASE_URL=postgres://postgres:password@db.your-project.supabase.co:5432/postgres

# Email sender for magic links (Resend). Needs a verified sender domain; until
# it verifies, onboarding@resend.dev only delivers to your own address.
RESEND_API_KEY=
# Optional override for the magic-link From address.
MAGIC_LINK_FROM=DottComm <onboarding@resend.dev>

# --- MCP server auth ---
# Enforce OAuth on the MCP endpoint. Leave unset/false for open local dev.
MCP_REQUIRE_AUTH=false

# This server's public MCP URL. Bound as the token `resource` by Better Auth
# (lib/auth.ts) and advertised in the protected-resource metadata. Example:
MCP_RESOURCE_URL=https://www.dottcomm.dev/api/mcp

# Dev only: with MCP_REQUIRE_AUTH=false, set a fake user id to exercise the
# billing gate without OAuth. Leave unset to run tools ungated locally.
MCP_DEV_USER_ID=

# --- Billing: Supabase entitlement/usage store (ADR 0002) ---
# Project URL + service_role key (server-only — the anon key is never used).
# This is the Supabase JS/PostgREST client used for the billing table only;
# Better Auth reaches the same database directly via DATABASE_URL above.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Free trial is two-phase: an upfront pool of tool calls usable at any pace,
# then a recurring daily allowance (resets at midnight, Europe/Rome).
TRIAL_TOOL_CALL_LIMIT=50
DAILY_TOOL_CALL_LIMIT=20

# Canonical site URL — used to build the /upgrade link inside tool responses.
NEXT_PUBLIC_SITE_URL=https://www.dottcomm.dev

# Secret for the short-lived signed token in the paywall /upgrade?t=… link,
# which lets a paywalled user reach Stripe Checkout without re-login. Optional:
# falls back to BETTER_AUTH_SECRET; if neither is set the link degrades to the
# plain /upgrade + sign-in flow. Generate with: openssl rand -base64 24
UPGRADE_TOKEN_SECRET=

# --- Billing: Stripe ---
STRIPE_SECRET_KEY=
# From the Dashboard webhook endpoint (prod) or `stripe listen` (local).
STRIPE_WEBHOOK_SECRET=
# The flat monthly subscription price.
STRIPE_PRICE_ID=
